<?xml version="1.0" encoding="utf-8"?>

<views:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Sample.Views"
    xmlns:viewModels="clr-namespace:Sample.ViewModels"
    x:Class="Sample.Views.HomePage"
    x:DataType="viewModels:HomeVm"
    BackgroundColor="{StaticResource Surface}"
    Title="MediaGallery">

    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

        <Label Text="MediaGallery Sample"
               FontSize="24" FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               TextColor="{StaticResource TextPrimary}" />

        <Label Text="Pick, capture and save media files"
               FontSize="14"
               HorizontalTextAlignment="Center"
               TextColor="{StaticResource TextSecondary}"
               Margin="0,0,0,16" />

        <Button Text="Pick Media" Command="{Binding NavigateToPickCommand, Mode=OneTime}" />
        <Button Text="Save Media" Command="{Binding NavigateToSaveCommand, Mode=OneTime}" />

    </VerticalStackLayout>
</views:BasePage>
